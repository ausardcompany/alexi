npx lint-staged

# Reject zero-width spaces (U+200B) and other invisible chars in workflows
# and TypeScript sources. Caused a real outage on 2026-05-29 when an
# editor injected U+200B into ${ { ... } } expressions in workflows.
if git diff --cached --name-only --diff-filter=AM | \
   xargs -r grep -l $'\xe2\x80\x8b' 2>/dev/null; then
  echo "✖ Refusing commit: file(s) above contain U+200B (zero-width space)."
  echo "  Run: perl -i -pe 's/\\x{200b}//g' <file> to remove."
  exit 1
fi
