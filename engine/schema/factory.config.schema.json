{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/ausardcompany/agent-factory/schema/factory.config.schema.json",
  "title": "Agent Factory project configuration",
  "description": "Per-project contract consumed by the reusable agent-factory engine. Lives at .agent-factory/factory.config.yml in a consumer repository.",
  "type": "object",
  "required": ["version", "models", "stack", "git", "roles"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "description": "Config schema version.",
      "enum": [1]
    },
    "engine": {
      "type": "string",
      "description": "Engine pin, e.g. 'ausardcompany/agent-factory@v1'.",
      "pattern": "^[^/]+/[^@]+@.+$"
    },
    "models": {
      "type": "object",
      "description": "Model tier -> concrete provider/model id.",
      "required": ["small", "big"],
      "additionalProperties": false,
      "properties": {
        "nano": { "type": "string", "minLength": 1 },
        "small": { "type": "string", "minLength": 1 },
        "big": { "type": "string", "minLength": 1 }
      }
    },
    "stack": {
      "type": "object",
      "description": "Build/test commands. type:none disables build-oriented gates for non-engineering projects.",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["node", "python", "go", "rust", "custom", "none"]
        },
        "install": { "type": "string" },
        "build": { "type": "string" },
        "test": { "type": "string" },
        "lint": { "type": "string" },
        "extra": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Additional gate commands run in order after lint."
        }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "not": { "const": "none" } } } },
          "then": { "required": ["install"] }
        }
      ]
    },
    "git": {
      "type": "object",
      "required": ["author_name", "author_email"],
      "additionalProperties": false,
      "properties": {
        "author_name": { "type": "string", "minLength": 1 },
        "author_email": { "type": "string", "minLength": 3, "pattern": "@" },
        "default_branch": { "type": "string", "default": "main" },
        "commit_scopes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "secrets": {
      "type": "object",
      "description": "Logical secret name -> GitHub secret name. Values never live here.",
      "additionalProperties": { "type": "string" }
    },
    "roles": {
      "type": "object",
      "description": "Per-role enablement, model tier, and watchdog timeout.",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean", "default": true },
          "tier": { "type": "string", "enum": ["nano", "small", "big"] },
          "timeout_minutes": { "type": "integer", "minimum": 1, "maximum": 360 }
        }
      }
    },
    "reliability": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "retries": { "type": "integer", "minimum": 0, "maximum": 10, "default": 2 },
        "escalation_label": { "type": "string", "default": "factory-escalation" },
        "transient_pattern": { "type": "string" }
      }
    },
    "sync": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["repo"],
            "additionalProperties": false,
            "properties": {
              "repo": { "type": "string", "pattern": "^[^/]+/[^/]+$" },
              "branch": { "type": "string", "default": "main" }
            }
          }
        }
      }
    }
  }
}
